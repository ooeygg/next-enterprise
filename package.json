{
  "name": "next-template",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "tsx scripts/build-theme-css.ts",
    "prebuild": "tsx scripts/build-theme-css.ts",
    "theme:build-css": "tsx scripts/build-theme-css.ts",
    "openapi:validate": "npx -y swagger-cli validate api/openapi.yaml",
    "openapi:lint": "npx -y @redocly/cli lint api/openapi.yaml",
    "openapi:preview": "npx -y @redocly/cli preview-docs api/openapi.yaml",
    "openapi:generate": "npx -y @openapitools/openapi-generator-cli generate -i api/openapi.yaml -g typescript-fetch -o packages/sdk",
    "dev": "FORCE_COLOR=1 next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "analyze": "ANALYZE=true pnpm run build",
    "test": "FORCE_COLOR=1 vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:production": "PRODUCTION_SMOKE=true playwright test --project=chromium e2e/production-smoke.spec.ts",
    "smoke:cleanup": "tsx scripts/production-smoke-cleanup.ts",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "email:test": "tsx scripts/email/send-test-resend.ts",
    "auth:email:test": "tsx scripts/email/auth-email-test.ts",
    "test:watch": "FORCE_COLOR=1 vitest --watch",
    "test:ui": "FORCE_COLOR=1 vitest --ui",
    "test:coverage": "FORCE_COLOR=1 vitest --coverage",
    "analytics:mcp": "node scripts/analytics-mcp.mjs start",
    "analytics:test": "node scripts/analytics-mcp.mjs test",
    "analytics:verify": "node scripts/analytics-mcp.mjs verify",
    "e2e:headless": "playwright test",
    "e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "coupling-graph": "npx madge --extensions js,jsx,ts,tsx,css,md,mdx ./ --exclude '.next|tailwind.config.js|reset.d.ts|prettier.config.js|postcss.config.js|playwright.config.ts|next.config.js|next-env.d.ts|instrumentation.ts|e2e/|README.md|.storybook/|.eslintrc.js' --image graph.svg"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/fiber": "^9.6.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@vercel/otel": "^2.1.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "ical-generator": "^11.0.0",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "next-auth": "4.24.14",
    "posthog-js": "^1.396.5",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.9",

    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-tailwindcss": "^4.0.5",
    "gzip-size": "7.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typed-query-selector": "^2.12.1",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.62.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "tmp@<=0.2.3": ">=0.2.4"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@prisma/client",
      "esbuild",
      "sharp"
    ]
  }
}
